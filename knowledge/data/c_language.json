    {"id": "io", "name": "输入输出", "category": "基础语法", "difficulty": 2, "chapter": 2, "description": "printf, scanf, 格式控制符", "estimated_minutes": 30},
    {"id": "operator", "name": "运算符与表达式", "category": "基础语法", "difficulty": 2, "chapter": 3, "description": "算术、关系、逻辑、位运算符，优先级", "estimated_minutes": 35},
    {"id": "type_cast", "name": "类型转换", "category": "基础语法", "difficulty": 2, "chapter": 3, "description": "隐式转换、强制转换", "estimated_minutes": 20},
    {"id": "if_else", "name": "条件语句(if/else)", "category": "控制结构", "difficulty": 2, "chapter": 4, "description": "if, if-else, if-else if-else, 嵌套", "estimated_minutes": 30},
