{
  "course": "c_language",
  "name": "C语言程序设计",
  "nodes": [
    {"id": "intro", "name": "程序设计概述", "category": "基础概念", "difficulty": 1, "chapter": 1, "description": "程序、算法、流程图基本概念；printf/return基础用法", "estimated_minutes": 20},
    {"id": "data_type", "name": "数据类型", "category": "基础语法", "difficulty": 1, "chapter": 2, "description": "int, float, double, char等基本数据类型及其取值范围", "estimated_minutes": 25},
    {"id": "var", "name": "变量与常量", "category": "基础语法", "difficulty": 1, "chapter": 2, "description": "变量定义、初始化、const常量、#define宏常量、命名规则", "estimated_minutes": 25},
    {"id": "io", "name": "输入输出", "category": "基础语法", "difficulty": 2, "chapter": 2, "description": "printf/scanf、格式控制符%d%f%lf%c%s、&取地址", "estimated_minutes": 30},
    {"id": "operator", "name": "运算符与表达式", "category": "基础语法", "difficulty": 2, "chapter": 3, "description": "算术、关系、逻辑、位运算符，自增自减，优先级与结合性", "estimated_minutes": 35},
    {"id": "type_cast", "name": "类型转换", "category": "基础语法", "difficulty": 2, "chapter": 3, "description": "隐式转换、强制类型转换(type)，整数除法与浮点除法", "estimated_minutes": 20},
    {"id": "if_else", "name": "条件语句(if/else/switch)", "category": "控制结构", "difficulty": 2, "chapter": 4, "description": "if、if-else、if-else if-else嵌套；switch-case-break-default", "estimated_minutes": 35},
    {"id": "for_loop", "name": "for循环", "category": "控制结构", "difficulty": 3, "chapter": 5, "description": "for语法、嵌套循环、循环变量、多重循环", "estimated_minutes": 35},
    {"id": "while_loop", "name": "while/do-while循环", "category": "控制结构", "difficulty": 3, "chapter": 5, "description": "while先判断再执行，do-while至少执行一次；多组输入EOF", "estimated_minutes": 30},
    {"id": "break_continue", "name": "break与continue", "category": "控制结构", "difficulty": 2, "chapter": 5, "description": "break退出循环，continue跳过本次；在switch和循环中的用法", "estimated_minutes": 20},
    {"id": "array_1d", "name": "一维数组", "category": "数组", "difficulty": 3, "chapter": 6, "description": "数组定义、初始化、遍历；冒泡/选择/插入排序；二分查找", "estimated_minutes": 45},
    {"id": "array_2d", "name": "二维数组", "category": "数组", "difficulty": 3, "chapter": 6, "description": "二维数组定义、矩阵操作、转置、乘法", "estimated_minutes": 35},
    {"id": "char_array", "name": "字符数组与字符串", "category": "数组", "difficulty": 3, "chapter": 6, "description": "字符数组、字符串函数(strlen/strcpy/strcat/strcmp)、大小写转换", "estimated_minutes": 40},
    {"id": "func_def", "name": "函数定义与调用", "category": "函数", "difficulty": 3, "chapter": 7, "description": "函数声明、定义、参数列表、返回值、函数原型", "estimated_minutes": 40},
    {"id": "func_param", "name": "函数参数传递", "category": "函数", "difficulty": 3, "chapter": 7, "description": "值传递与地址传递；形参和实参；无法通过值传递修改实参", "estimated_minutes": 30},
    {"id": "scope", "name": "变量作用域", "category": "函数", "difficulty": 3, "chapter": 7, "description": "局部变量、全局变量、static变量；生命周期与可见性", "estimated_minutes": 25},
    {"id": "recursion", "name": "递归", "category": "函数", "difficulty": 4, "chapter": 7, "description": "递归思想、终止条件、递归调用；阶乘、斐波那契、汉诺塔", "estimated_minutes": 45},
    {"id": "ptr_basic", "name": "指针基础", "category": "指针", "difficulty": 4, "chapter": 8, "description": "指针概念、&和*运算符、指针变量声明、NULL指针", "estimated_minutes": 45},
    {"id": "ptr_array", "name": "指针与数组", "category": "指针", "difficulty": 4, "chapter": 8, "description": "数组名与指针、指针运算、*(p+i)等价arr[i]、指针遍历数组", "estimated_minutes": 40},
    {"id": "ptr_string", "name": "指针与字符串", "category": "指针", "difficulty": 4, "chapter": 8, "description": "字符指针、字符串字面量只读性、strstr/strchr等函数", "estimated_minutes": 35},
    {"id": "ptr_func", "name": "函数指针", "category": "指针", "difficulty": 5, "chapter": 8, "description": "函数指针定义、回调函数、qsort的比较函数", "estimated_minutes": 40},
    {"id": "ptr_ptr", "name": "指针的指针", "category": "指针", "difficulty": 5, "chapter": 8, "description": "二级指针、指针数组char*[]、argv参数", "estimated_minutes": 35},
    {"id": "struct_basic", "name": "结构体基础", "category": "结构体", "difficulty": 3, "chapter": 9, "description": "结构体定义、成员访问(.)、结构体数组、初始化", "estimated_minutes": 35},
    {"id": "struct_ptr", "name": "结构体指针", "category": "结构体", "difficulty": 4, "chapter": 9, "description": "结构体指针、->运算符、传递结构体指针到函数", "estimated_minutes": 30},
    {"id": "typedef", "name": "typedef与枚举", "category": "结构体", "difficulty": 2, "chapter": 9, "description": "typedef类型别名、enum枚举类型；简化结构体名称", "estimated_minutes": 20},
    {"id": "dynamic_mem", "name": "动态内存分配", "category": "高级主题", "difficulty": 5, "chapter": 10, "description": "malloc/calloc/realloc/free；堆内存、内存泄漏防范", "estimated_minutes": 45},
    {"id": "linked_list", "name": "链表", "category": "高级主题", "difficulty": 5, "chapter": 10, "description": "单链表创建、插入、删除、遍历；节点定义；与数组比较", "estimated_minutes": 60},
    {"id": "file_io", "name": "文件操作", "category": "高级主题", "difficulty": 4, "chapter": 11, "description": "fopen/fclose/fread/fwrite/fprintf/fscanf/fgets；文件读写模式", "estimated_minutes": 40},
    {"id": "preprocess", "name": "预处理与宏", "category": "高级主题", "difficulty": 3, "chapter": 12, "description": "#include/#define/#ifdef；宏函数、条件编译、头文件保护", "estimated_minutes": 30},
    {"id": "bitwise", "name": "位运算", "category": "高级主题", "difficulty": 4, "chapter": 12, "description": "&/|/^/~/<</>>;置位、清位、检测位；无符号数处理", "estimated_minutes": 35},
    {"id": "sort_algo", "name": "排序算法", "category": "算法应用", "difficulty": 4, "chapter": 13, "description": "冒泡/选择/插入排序原理与实现；qsort标准库；时间复杂度", "estimated_minutes": 50},
    {"id": "search_algo", "name": "查找算法", "category": "算法应用", "difficulty": 3, "chapter": 13, "description": "顺序查找（有序优化）、二分查找；索引查找；时间复杂度对比", "estimated_minutes": 35}
  ],
